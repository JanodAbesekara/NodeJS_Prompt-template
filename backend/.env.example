# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB
# Replace <username>, <password>, and <database> with your own values.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.8rrk4at.mongodb.net/<database>?retryWrites=true&w=majority

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=SecretAccessKey1234567890
JWT_REFRESH_SECRET=SecretRefreshKey1234567890
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin seed (used by: npm run seed)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeMe123

# Optional: set to true to upsert admin on server start (development only)
SEED_ADMIN_ON_START=false
